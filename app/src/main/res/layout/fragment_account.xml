<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipToPadding="true"
    android:fillViewport="true"
    android:paddingBottom="28dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="12dp"
            android:text="@string/account_header_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/sarif_on_surface_muted" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/sarif_surface"
            app:cardElevation="0dp"
            app:contentPadding="18dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Sarif.Dashboard.Tile"
            app:strokeColor="@color/sarif_dashboard_stroke"
            app:strokeWidth="@dimen/sarif_card_stroke_width">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_section_profile"
                    android:textAppearance="@style/TextAppearance.Sarif.TitleMedium"
                    android:textColor="@color/sarif_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_account_phone"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/textAccountPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    tools:text="+252 63 400 0111" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_session_status"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/textSessionStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/value_session_signed_in"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/sarif_surface"
            app:cardElevation="0dp"
            app:contentPadding="18dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Sarif.Dashboard.Tile"
            app:strokeColor="@color/sarif_dashboard_stroke"
            app:strokeWidth="@dimen/sarif_card_stroke_width">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_section_license"
                    android:textAppearance="@style/TextAppearance.Sarif.TitleMedium"
                    android:textColor="@color/sarif_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_license_status"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/textLicenseStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    tools:text="Active" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_license_activated_on"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/textLicenseDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    tools:text="May 3, 2026, 10:15 PM" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_license_key_reference"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/textLicenseKeyHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="Ends with …ACTIVATE" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/sarif_surface"
            app:cardElevation="0dp"
            app:contentPadding="18dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Sarif.Dashboard.Tile"
            app:strokeColor="@color/sarif_dashboard_stroke"
            app:strokeWidth="@dimen/sarif_card_stroke_width">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_section_app"
                    android:textAppearance="@style/TextAppearance.Sarif.TitleMedium"
                    android:textColor="@color/sarif_primary" />

                <TextView
                    android:id="@+id/textAppVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    tools:text="Version 1.0" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/account_logout_hint"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/sarif_on_surface_muted" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="56dp"
            android:stateListAnimator="@null"
            android:text="@string/btn_logout_account"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/sarif_accent"
            app:cornerRadius="32dp"
            app:elevation="0dp"
            app:rippleColor="@color/hero_button_ripple" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
