<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sarif_background"
    android:fillViewport="true"
    android:paddingHorizontal="@dimen/sarif_horizontal_inset"
    android:paddingVertical="20dp"
    tools:context=".LicenseActivity">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        app:cardBackgroundColor="@color/sarif_surface"
        app:cardElevation="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Sarif.Dashboard.Tile"
        app:strokeColor="@color/sarif_dashboard_stroke"
        app:strokeWidth="@dimen/sarif_card_stroke_width">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/license_title"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textColor="@color/sarif_on_surface" />

            <TextView
                android:id="@+id/textLicenseVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/sarif_on_surface_muted"
                tools:text="Version 1.0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/license_body"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/sarif_on_surface" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/hint_license_key">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputLicenseKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapCharacters"
                    android:maxLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/license_demo_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/sarif_on_surface_muted" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActivateLicense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:minHeight="56dp"
                android:stateListAnimator="@null"
                android:text="@string/btn_activate_license"
                android:textAllCaps="false"
                app:backgroundTint="@color/sarif_primary"
                app:cornerRadius="16dp"
                app:elevation="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>
