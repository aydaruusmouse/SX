<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:orientation="vertical"
    tools:context=".SettingsActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/sarif_surface"
        android:elevation="0dp"
        app:navigationIconTint="@color/sarif_on_surface"
        app:title="@string/settings_title"
        app:titleTextAppearance="@style/TextAppearance.Sarif.TitleLarge"
        app:titleTextColor="@color/sarif_on_surface" />

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:dividerColor="@color/sarif_outline_soft" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/settingsFragmentHost"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:clipToPadding="true"
        android:paddingStart="@dimen/sarif_horizontal_inset"
        android:paddingEnd="@dimen/sarif_horizontal_inset" />
</LinearLayout>
