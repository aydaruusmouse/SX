    <string name="notify_text">Sequential USSD loop running</string>
    <string name="disclaimer_short">USSD behavior depends on your carrier and Android version. Many networks need one stacked code per step or manual confirmation. Storing a PIN on the device is risky—use only on a phone you control.</string>
    <string name="label_last_balance_placeholder">Last balance: —</string>
