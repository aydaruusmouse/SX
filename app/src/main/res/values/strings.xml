    <string name="label_ax_ussd_pin">Enter PIN via Accessibility (USSD dialog)</string>
    <string name="btn_accessibility_settings">Open Accessibility settings</string>
    <string name="accessibility_service_description">Sarif Auto can type your service PIN into the system USSD window after *222#, because the phone API often does not accept a second PIN-only USSD request. Enable only if you trust this app.</string>
    <string name="toast_enable_accessibility">Turn on the switch above, then enable “Sarif Auto” under Downloaded apps in Accessibility.</string>
    <string name="hint_balance_steps">Balance check only — not the bank-transfer box below. One line per step. Default Hormuud: *222#. Telesom balance is usually *800#, service PIN, then 1 on the ZAAD balance menu. The app will not auto-press 1 on the Telesom “Diwaangeli / Caawimo” root menu. You can split *800# and {PIN} across lines. After “Enter PIN”, only digits are sent.</string>
    <string name="hint_transfer_amount">Transfer amount {AMOUNT} — leave empty to use balance minus reserve</string>
    <string name="hint_transfer_reserve">Keep in wallet when using balance (not full sweep; default 100)</string>
    <string name="hint_transfer_bank_pin">Bank / second PIN for `{BANK_PIN}` in send steps (digits only)</string>
    <string name="hint_send_steps">Bank / ZAAD transfer — different from balance lines above. Typical Telesom flow uses *800#, {PIN}, then menu keys 5, 2, 4, 1, then {AMOUNT} and {BANK_PIN} as in the default template — not the short *800# + PIN + 1 path used for balance. {AMOUNT} is whole units (1.4 → 1). *220*…# stacked codes still work.</string>
